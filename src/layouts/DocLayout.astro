          function card(e, color, border) {
            const rows = e.fields
              .map((f) => {
                const isPK = f.includes("PK");
                const isFK = f.includes("FK");
                const clean = f.replace(" PK", "").replace(" FK", "");
                const bg = isPK ? "#faf5ff" : isFK ? "#f8fafc" : "transparent";
                const tc = isPK ? "#6d28d9" : isFK ? "#64748b" : "#374151";
                const fw = isPK ? "600" : "400";
                const badge = isPK
                  ? '<span style="font-size:9px;font-weight:700;color:#7c3aed;background:#ede9fe;padding:1px 5px;border-radius:3px;margin-left:5px;">PK</span>'
