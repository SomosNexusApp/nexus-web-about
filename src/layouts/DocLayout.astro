            + String nombre<br/>+ String avatarUrl<br/>+ String telefono<br/>
            + TipoCuenta tipoCuenta<br/>+ boolean cuentaVerificada<br/>
            + boolean cuentaEliminada<br/>+ String stripeCustomerId<br/>
            + String twoFactorSecret<br/>+ boolean twoFactorEnabled<br/>
            + LocalDateTime creadoEn
          </div>
        </div>

        <svg width="620" height="60" style="display:block;overflow:visible;">
          <line x1="310" y1="0" x2="310" y2="30" stroke="#9d5ae5" stroke-width="2"/>
          <line x1="100" y1="30" x2="520" y2="30" stroke="#9d5ae5" stroke-width="2"/>
