<script is:inline>
    (function () {
        var modal = document.getElementById("img-modal");
        var overlay = document.getElementById("img-modal-overlay");
        var modalImg = document.getElementById("img-modal-img");
        var caption = document.getElementById("img-modal-caption");
        var viewport = document.getElementById("img-modal-viewport");
        var zoomLevelEl = document.getElementById("img-zoom-level");
        var btnZoomIn = document.getElementById("img-zoom-in");
        var btnZoomOut = document.getElementById("img-zoom-out");
        var btnReset = document.getElementById("img-zoom-reset");
        var btnClose = document.getElementById("img-modal-close");
        if (!modal) return;
        var scale = 1,
            tx = 0,
            ty = 0,
            minS = 0.4,
            maxS = 6,
            isDrag = false,
            dsx = 0,
            dsy = 0,
            ltx = 0,
            lty = 0,
            lpd = 0,
            pinch = false;
        function upd(anim) {
            modalImg.style.transition = anim
                ? "transform 0.25s cubic-bezier(0.4,0,0.2,1)"
                : "none";
            modalImg.style.transform =
                "translate(calc(-50% + " +
                tx +
                "px), calc(-50% + " +
                ty +
                "px)) scale(" +
                scale +
                ")";
            zoomLevelEl.textContent = Math.round(scale * 100) + "%";
        }
        function clamp() {
            if (scale <= 1) {
                tx = 0;
                ty = 0;
                return;
            }
            var vw = viewport.clientWidth,
                vh = viewport.clientHeight;
            var iw = modalImg.naturalWidth || modalImg.clientWidth,
                ih = modalImg.naturalHeight || modalImg.clientHeight;
            var mx = Math.max(0, (iw * scale - vw) / 2),
                my = Math.max(0, (ih * scale - vh) / 2);
            tx = Math.min(mx, Math.max(-mx, tx));
            ty = Math.min(my, Math.max(-my, ty));
        }
        function fitScale() {
            var vw = viewport.clientWidth || 800;
            var vh = viewport.clientHeight || 600;
            var iw = modalImg.naturalWidth || modalImg.width || vw;
            var ih = modalImg.naturalHeight || modalImg.height || vh;
            if (!iw || !ih) return 1;
            var s = Math.min(vw / iw, vh / ih);
            return Math.min(s, 1); // never enlarge beyond 100%
        }
        function open(src, alt) {
            modal.classList.add("open");
            document.body.style.overflow = "hidden";
            caption.textContent = alt || "";
            tx = 0;
            ty = 0;
            modalImg.style.transition = "none";
            modalImg.alt = alt || "";
            modalImg.src = src;
            // wait for image to load to get natural dimensions, then fit
            modalImg.onload = function () {
                scale = fitScale();
                upd(false);
                modalImg.onload = null;
            };
            // if already cached (complete), trigger immediately
            if (modalImg.complete && modalImg.naturalWidth) {
                scale = fitScale();
                upd(false);
                modalImg.onload = null;
            } else {
                scale = 0.64;
                upd(false); // fallback while loading
            }
        }
        function close() {
            modal.classList.remove("open");
            document.body.style.overflow = "";
            setTimeout(function () {
                modalImg.src = "";
            }, 350);
        }
        function zoomAt(f, cx, cy) {
            var ns = Math.min(maxS, Math.max(minS, scale * f));
            if (ns === scale) return;
            var vw = viewport.clientWidth,
                vh = viewport.clientHeight;
            var px = cx - vw / 2 - tx,
                py = cy - vh / 2 - ty,
                r = ns / scale;
            tx -= px * (r - 1);
            ty -= py * (r - 1);
            scale = ns;
            clamp();
            upd(false);
        }
        // Event delegation: capture clicks on any img inside .pf-screenshot anywhere in the document
        document.addEventListener(
            "click",
            function (e) {
                var target = e.target;
                if (
                    target &&
                    target.tagName === "IMG" &&
                    target.closest &&
                    (target.closest(".pf-screenshot") ||
                        target.closest(".ut-shot"))
                ) {
                    e.stopPropagation();
                    open(target.src, target.alt);
                }
            },
            true,
        );
        btnClose.addEventListener("click", close);
        overlay.addEventListener("click", close);
        document.addEventListener("keydown", function (e) {
            if (!modal.classList.contains("open")) return;
            if (e.key === "Escape") close();
            var c = viewport.clientWidth / 2,
                m = viewport.clientHeight / 2;
            if (e.key === "+" || e.key === "=") {
                zoomAt(1.3, c, m);
                upd(true);
            }
            if (e.key === "-") {
                zoomAt(1 / 1.3, c, m);
                upd(true);
            }
            if (e.key === "0") {
                scale = 1;
                tx = 0;
                ty = 0;
                upd(true);
            }
        });
        btnZoomIn.addEventListener("click", function () {
            zoomAt(1.4, viewport.clientWidth / 2, viewport.clientHeight / 2);
            upd(true);
        });
        btnZoomOut.addEventListener("click", function () {
            zoomAt(
                1 / 1.4,
                viewport.clientWidth / 2,
                viewport.clientHeight / 2,
            );
            upd(true);
        });
        btnReset.addEventListener("click", function () {
            scale = fitScale();
            tx = 0;
            ty = 0;
            upd(true);
        });
        viewport.addEventListener(
            "wheel",
            function (e) {
                e.preventDefault();
                var r = viewport.getBoundingClientRect();
                zoomAt(
                    e.deltaY < 0 ? 1.12 : 1 / 1.12,
                    e.clientX - r.left,
                    e.clientY - r.top,
                );
            },
            { passive: false },
        );
        viewport.addEventListener("mousedown", function (e) {
            if (e.button !== 0) return;
            isDrag = true;
            dsx = e.clientX;
            dsy = e.clientY;
            ltx = tx;
            lty = ty;
            viewport.classList.add("grabbing");
            e.preventDefault();
        });
        window.addEventListener("mousemove", function (e) {
            if (!isDrag) return;
            tx = ltx + e.clientX - dsx;
            ty = lty + e.clientY - dsy;
            clamp();
            upd(false);
        });
        window.addEventListener("mouseup", function () {
            if (isDrag) {
                isDrag = false;
                viewport.classList.remove("grabbing");
            }
        });
        var tsx = 0,
            tsy = 0,
            tlx = 0,
            tly = 0;
        viewport.addEventListener(
            "touchstart",
            function (e) {
                if (e.touches.length === 2) {
                    pinch = true;
                    var dx = e.touches[0].clientX - e.touches[1].clientX,
                        dy = e.touches[0].clientY - e.touches[1].clientY;
                    lpd = Math.sqrt(dx * dx + dy * dy);
                } else if (e.touches.length === 1) {
                    pinch = false;
                    tsx = e.touches[0].clientX;
                    tsy = e.touches[0].clientY;
                    tlx = tx;
                    tly = ty;
                }
            },
            { passive: true },
        );
        viewport.addEventListener(
            "touchmove",
            function (e) {
                if (e.touches.length === 2 && pinch) {
                    e.preventDefault();
                    var dx = e.touches[0].clientX - e.touches[1].clientX,
                        dy = e.touches[0].clientY - e.touches[1].clientY;
                    var d = Math.sqrt(dx * dx + dy * dy),
                        r = viewport.getBoundingClientRect();
                    var cx =
                            (e.touches[0].clientX + e.touches[1].clientX) / 2 -
                            r.left,
                        cy =
                            (e.touches[0].clientY + e.touches[1].clientY) / 2 -
                            r.top;
                    zoomAt(d / lpd, cx, cy);
                    lpd = d;
                } else if (e.touches.length === 1 && !pinch && scale > 1) {
                    e.preventDefault();
                    tx = tlx + e.touches[0].clientX - tsx;
                    ty = tly + e.touches[0].clientY - tsy;
                    clamp();
                    upd(false);
                }
            },
            { passive: false },
        );
        viewport.addEventListener(
            "touchend",
            function (e) {
                if (e.touches.length < 2) pinch = false;
            },
            { passive: true },
        );
    })();
</script>
