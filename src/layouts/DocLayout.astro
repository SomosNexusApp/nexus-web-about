        if (erEl) {
            function field(f) {
                const isPK = f.includes("PK");
                const isFK = f.includes("FK");
                const clean = f.replace(" PK", "").replace(" FK", "");
                const bg = isPK ? "#faf5ff" : isFK ? "#f0f9ff" : "transparent";
                const tc = isPK ? "#6d28d9" : isFK ? "#0369a1" : "#374151";
                const fw = isPK ? "600" : "400";
                const badge = isPK
                    ? '<span style="font-size:9px;font-weight:700;color:#7c3aed;background:#ede9fe;padding:1px 6px;border-radius:3px;margin-left:5px;vertical-align:middle;">PK</span>'
                    : isFK
                      ? '<span style="font-size:9px;font-weight:700;color:#0369a1;background:#dbeafe;padding:1px 6px;border-radius:3px;margin-left:5px;vertical-align:middle;">FK</span>'
                      : "";
                return `<tr style="background:${bg};border-bottom:1px solid #f1f5f9;">
        <td style="padding:4px 12px;font-size:11.5px;font-weight:${fw};color:${tc};font-family:monospace;white-space:nowrap;">${clean}${badge}</td>
      </tr>`;
            }

            function card(e, color, border) {
                return `<div style="border:1.5px solid ${border};border-radius:10px;overflow:hidden;background:#fff;min-width:190px;flex:1 1 180px;box-shadow:0 1px 4px rgba(0,0,0,0.06);">
        <div style="background:${color};color:#fff;font-size:12px;font-weight:700;padding:7px 12px;letter-spacing:.02em;">${e.name}</div>
        <table style="width:100%;border-collapse:collapse;">${e.fields.map(field).join("")}</table>
      </div>`;
            }

            function relBlock(rels, color) {
                if (!rels || !rels.length) return "";
                return `<div style="margin-top:14px;border:1px solid #e2e8f0;border-radius:10px;overflow:hidden;font-family:'Inter',sans-serif;">
        <div style="background:#f8fafc;padding:6px 14px;font-size:10.5px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:.08em;border-bottom:1px solid #e2e8f0;">Relaciones</div>
        <div style="display:flex;flex-direction:column;gap:0;">
          ${rels
              .map(
                  (r) => `
          <div style="display:flex;align-items:center;gap:0;border-bottom:1px solid #f1f5f9;padding:7px 14px;flex-wrap:wrap;gap:8px;">
            <code style="font-size:12px;font-weight:600;color:#1e293b;background:#f1f5f9;padding:2px 7px;border-radius:4px;">${r.from}</code>
            <span style="font-size:13px;color:#94a3b8;margin:0 2px;">──</span>
            <span style="display:inline-block;background:${color}18;color:${color};font-size:11px;font-weight:700;padding:2px 10px;border-radius:20px;border:1px solid ${color}55;white-space:nowrap;">${r.card}</span>
            <span style="font-size:13px;color:#94a3b8;margin:0 2px;">──</span>
            <code style="font-size:12px;font-weight:600;color:#1e293b;background:#f1f5f9;padding:2px 7px;border-radius:4px;">${r.to}</code>
            <span style="font-size:11.5px;color:#64748b;font-style:italic;margin-left:6px;">${r.label}</span>
          </div>`,
              )
              .join("")}
        </div>
      </div>`;
            }

