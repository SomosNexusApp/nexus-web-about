---
import BaseHead from "../components/BaseHead.astro";

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = "Documentación técnica detallada de Nexus App: arquitectura, diseño y manual de usuario.",
  image = "/assets/identidad/logotipo.webp",
} = Astro.props;
const currentYear = new Date().getFullYear();

// Documentos para el panel lateral
const docs = [
  {
    title: "Documento General",
    items: [
      { name: "Introducción y Contexto", id: "introduccion" },
      { name: "Análisis y Requisitos", id: "analisis" },
      { name: "Diseño", id: "diseno" },
      { name: "Implementación", id: "implementacion" },
      { name: "Pruebas y Evaluación", id: "pruebas" },
      { name: "Conclusiones y Mejoras", id: "conclusiones" },
      { name: "Bibliografía", id: "bibliografia" },
      { name: "Anexos", id: "anexos" },
    ],
  },
  {
    title: "Otros Documentos",
    items: [
      { name: "Plan de Proyecto", id: "plan-proyecto" },
      { name: "Estudio de Viabilidad", id: "viabilidad" },
      { name: "Requisitos del Sistema", id: "requisitos-sistema" },
      { name: "Diagrama UML", id: "uml" },
      {
        name: "Mockup Interactivo",
        id: "mockup",
        icon: "/assets/herramientas/figma.png",
      },
    ],
  },
];
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead title={title} description={description} image={image} />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Caveat:wght@700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="light-theme">
    
    <nav class="site-nav">
      <div class="nav-brand">
        <a href="/">
          <img src="/assets/identidad/logotipo.webp" alt="Nexus Logo" class="brand-logo" style="height: 48px; width: auto;" />
        </a>
      </div>

      <div class="nav-contact doc-hide-mobile">
        <span style="font-weight: 700; font-size: 14px;">Contáctanos</span>
        <span class="nav-line"></span>
        <span style="color: var(--text-secondary); font-size: 14px;">somosnexusapp@gmail.com</span>
      </div>

      <div class="nav-socials doc-hide-mobile">
        <a href="https://www.instagram.com/nexusapp_es/" target="_blank" class="social-icon" aria-label="Instagram">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
        </a>
        <a href="https://x.com/somosnexusapp" target="_blank" class="social-icon" aria-label="X (Twitter)">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4l11.733 16h4.267l-11.733 -16z"></path>
            <path d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772"></path>
          </svg>
        </a>
        <a href="https://www.linkedin.com/company/ecentia-marketing/" target="_blank" class="social-icon" aria-label="LinkedIn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
            <rect x="2" y="9" width="4" height="12"></rect>
            <circle cx="4" cy="4" r="2"></circle>
          </svg>
        </a>
        <a href="https://github.com/SomosNexusApp/" target="_blank" class="social-icon" aria-label="GitHub">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
          </svg>
        </a>
      </div>

      <div class="mobile-actions">
        <button class="index-btn" id="index-toggle" style="display: none;">
          <span>Índice</span>
        </button>
        <button class="hamburger" id="menu-toggle" aria-label="Menu">
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
        </button>
      </div>

      <div class="nav-links header-inline-nav" id="nav-links">
        <a href="/#hero">Inicio</a>
        <a href="/documentacion">Documentación</a>
        <a href="/tecnologias">Tecnologías</a>
        <a href="/blog">Blog</a>
        <a href="/ayuda">Ayuda</a>
      </div>

      <div class="mobile-index-drawer" id="index-drawer">
        <div class="drawer-header">
          <h3>Tabla de Contenidos</h3>
          <button id="close-index" class="close-drawer">&times;</button>
        </div>
        <div class="drawer-body">
          {
            docs.map((section) => (
              <div class="sidebar-section">
                <h3>{section.title}</h3>
                <ul>
                  {section.items.map((item) => (
                    <li>
                      <a href={`#${item.id}`} class="drawer-link">
                        {item.name}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </div>
      <div class="drawer-overlay" id="drawer-overlay"></div>
    </nav>
    <div class="doc-layout">
      <aside class="sidebar">
        <div class="sidebar-content">
          {
            docs.map((section) => (
              <div class="sidebar-section">
                <h3>{section.title}</h3>
                <ul>
                  {section.items.map((item) => (
                    <li>
                      <a href={`#${item.id}`} class="sidebar-link">
                        {item.name}
                        {(item as any).icon && (
                          <img
                            src={(item as any).icon}
                            alt={item.name}
                            class="sidebar-icon"
                          />
                        )}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </aside>

      <main class="content">
        <slot />
        <footer class="doc-footer">
          <p>
            &copy; {currentYear} Nexus App - Documentación Técnica | <a
              href="/legal/aviso-legal"
              style="color: inherit; text-decoration: underline;">Legal</a
            > | <a
              href="/legal/privacidad"
              style="color: inherit; text-decoration: underline;">Privacidad</a
            > | <a
              href="/legal/terminos"
              style="color: inherit; text-decoration: underline;">Términos</a
            > | <a
              href="/legal/cookies"
              style="color: inherit; text-decoration: underline;">Cookies</a
            > | <a
              href="/legal/accesibilidad"
              style="color: inherit; text-decoration: underline;"
              >Accesibilidad</a>
          </p>
        </footer>
      </main>
    </div>

    <style is:global>
      /* IMPORTAMOS TUS ESTILOS GLOBALES PARA QUE EL NAV SE VEA BIEN */
      @import "../styles/variables.css";
      @import "../styles/base.css";
      @import "../styles/components.css";

      :root {
        --doc-bg: #ffffff;
        --doc-sidebar-bg: #f8f9fa;
        --doc-text: #1a1a1a;
        --doc-text-muted: #666666;
        --doc-accent: #9d5ae5;
        --doc-accent-soft: rgba(157, 90, 229, 0.1);
        --doc-border: #eef0f2;
        --doc-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body.light-theme {
        background-color: var(--doc-bg);
        color: var(--doc-text);
        font-family: "Inter", sans-serif;
        line-height: 1.6;
        overflow-x: hidden;
      }

      /* Layout */
      .doc-layout {
        display: flex;
        min-height: 100vh;
        padding-top: 70px; /* Margen para el nav */
        max-width: 1400px;
        margin: 0 auto;
      }

      /* Sidebar */
      .sidebar {
        width: 280px;
        height: calc(100vh - 70px);
        position: sticky;
        top: 70px;
        background: var(--doc-sidebar-bg);
        border-right: 1px solid var(--doc-border);
        padding: 2rem;
        overflow-y: auto;
      }

      .sidebar-section {
        margin-bottom: 2rem;
      }

      .sidebar-section h3 {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--doc-text-muted);
        margin-bottom: 1rem;
        font-weight: 700;
      }

      .sidebar-section ul {
        list-style: none;
      }

      .sidebar-link {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 0.5rem 0;
        color: var(--doc-text);
        text-decoration: none;
        font-size: 0.95rem;
        transition: all 0.3s;
        border-left: 2px solid transparent;
        padding-left: 12px;
        margin-left: -12px;
      }

      .sidebar-icon {
        width: 16px;
        height: 16px;
        object-fit: contain;
      }

      .sidebar-link:hover {
        color: var(--doc-accent);
        padding-left: 16px;
      }

      .sidebar-link.active {
        color: var(--doc-accent);
        font-weight: 600;
        border-left-color: var(--doc-accent);
        background: var(--doc-accent-soft);
      }

      /* Main Content */
      .content {
        flex: 1;
        padding: 3rem 4rem;
        max-width: 900px;
      }

      .content h1 {
        font-size: 3rem;
        font-weight: 800;
        margin-bottom: 1.5rem;
        letter-spacing: -0.02em;
      }

      .content h2 {
        font-size: 2rem;
        font-weight: 700;
        margin: 3rem 0 1.5rem;
        scroll-margin-top: 100px;
      }

      .content p {
        font-size: 1.1rem;
        color: #444;
        margin-bottom: 1.5rem;
        line-height: 1.8;
      }

      .content .lead {
        font-size: 1.25rem;
        color: var(--doc-text-muted);
        margin-bottom: 2rem;
      }

      /* Cards and elements */
      .doc-card {
        background: white;
        border: 1px solid var(--doc-border);
        border-radius: 12px;
        padding: 2rem;
        margin-bottom: 2rem;
        transition:
          transform 0.3s,
          box-shadow 0.3s;
        box-shadow: var(--doc-shadow);
      }

      .doc-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
      }

      .doc-footer {
        margin-top: 4rem;
        padding-top: 2rem;
        border-top: 1px solid var(--doc-border);
        color: var(--doc-text-muted);
        font-size: 0.9rem;
      }

      /* Ajustes Responsivos Nav + Docs */
      .mobile-actions {
        display: flex;
        align-items: center;
        gap: 12px;
      }

      @media (max-width: 1024px) {
        .doc-hide-mobile {
          display: none !important;
        }

        #index-toggle {
          display: flex !important;
        }

        .index-btn {
          display: flex;
          align-items: center;
          gap: 8px;
          padding: 6px 12px;
          background: #f0f0f0;
          border: 1px solid #ddd;
          border-radius: 8px;
          font-size: 13px;
          font-weight: 700;
          color: #333;
          cursor: pointer;
          transition: all 0.3s;
        }

        .index-btn:hover {
          background: #e5e5e5;
        }

        .header-inline-nav {
          display: none !important; 
        }

        .site-nav .hamburger {
          display: block !important;
        }

        .is-menu-open .header-inline-nav {
          display: flex !important;
          flex-direction: column;
          position: fixed;
          top: 0;
          left: 0;
          width: 100%;
          height: 100vh;
          background: rgba(255, 255, 255, 0.98) !important;
          backdrop-filter: blur(15px);
          padding: 100px 40px;
          gap: 30px;
          z-index: 2500;
          align-items: center;
          justify-content: flex-start;
          overflow-y: auto;
        }

        .is-menu-open .header-inline-nav a {
          color: #000 !important;
          font-size: 24px;
          font-weight: 700;
          text-transform: uppercase;
          letter-spacing: 1px;
          text-decoration: none;
        }

        /* Cajón de Índice */
        .mobile-index-drawer {
          position: fixed;
          top: 0;
          right: -100%;
          width: 85%;
          max-width: 320px;
          height: 100vh;
          background: #fff;
          z-index: 3000;
          transition: right 0.4s cubic-bezier(0.16, 1, 0.3, 1);
          display: flex;
          flex-direction: column;
          box-shadow: -10px 0 30px rgba(0, 0, 0, 0.1);
        }

        .mobile-index-drawer.open {
          right: 0;
        }

        .drawer-header {
          padding: 20px;
          border-bottom: 1px solid #eee;
          display: flex;
          justify-content: space-between;
          align-items: center;
          background: #fafafa;
        }

        .drawer-header h3 {
          font-size: 1rem;
          font-weight: 800;
          margin: 0;
          text-transform: uppercase;
          letter-spacing: 0.5px;
        }

        .close-drawer {
          background: none;
          border: none;
          font-size: 28px;
          color: #888;
          cursor: pointer;
          line-height: 1;
        }

        .drawer-body {
          padding: 20px;
          overflow-y: auto;
          flex: 1;
        }

        .drawer-link {
          display: block;
          padding: 12px 15px;
          color: #444;
          text-decoration: none;
          font-size: 0.95rem;
          border-radius: 8px;
          margin-bottom: 4px;
          transition: all 0.2s;
        }

        .drawer-link:active,
        .drawer-link:hover {
          background: var(--doc-accent-soft);
          color: var(--doc-accent);
        }

        .drawer-overlay {
          position: fixed;
          top: 0;
          left: 0;
          width: 100%;
          height: 100%;
          background: rgba(0, 0, 0, 0.5);
          backdrop-filter: blur(4px);
          z-index: 2900;
          opacity: 0;
          visibility: hidden;
          transition: all 0.3s;
        }

        .drawer-overlay.visible {
          opacity: 1;
          visibility: visible;
        }

        /* Hamburger Active Animation */
        .hamburger.active .hamburger-line:nth-child(1) {
          transform: translateY(8px) rotate(45deg);
        }
        .hamburger.active .hamburger-line:nth-child(2) {
          opacity: 0;
          transform: translateX(10px);
        }
        .hamburger.active .hamburger-line:nth-child(3) {
          transform: translateY(-8px) rotate(-45deg);
        }

        .sidebar {
          display: none;
        }
        .content {
          padding: 2rem 1.5rem;
        }
        .doc-layout {
          display: block;
        }
      }
    </style>
    
    <script
      is:inline
      src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"
    ></script>
    <script
      is:inline
      src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"
    ></script>

    <script>
      // GSAP Animations
      document.addEventListener("DOMContentLoaded", () => {
        // @ts-ignore
        if (typeof gsap !== "undefined") {
          // @ts-ignore
          gsap.from(".sidebar", {
            x: -100,
            opacity: 0,
            duration: 1,
            ease: "power4.out",
          });

          // @ts-ignore
          gsap.from(".content section", {
            y: 50,
            opacity: 0,
            duration: 0.8,
            stagger: 0.2,
            ease: "power3.out",
          });
        }
      });

      // Scroll Spy Logic
      const sections = document.querySelectorAll("section[id]");
      const navLinks = document.querySelectorAll(".sidebar-link");

      window.addEventListener("scroll", () => {
        let current = "";
        sections.forEach((section) => {
          const htmlSection = section as HTMLElement;
          const sectionTop = htmlSection.offsetTop;
          if (window.scrollY >= sectionTop - 150) {
            current = section.getAttribute("id") || "";
          }
        });

        navLinks.forEach((link) => {
          link.classList.remove("active");
          const href = link.getAttribute("href");
          if (href && current && href.includes(current)) {
            link.classList.add("active");
          }
        });
      });

      // Menu & Index Logic combinada
      function initMenu() {
        const menuToggle = document.getElementById("menu-toggle");
        const navLinksMobile = document.getElementById("nav-links");
        const siteNav = document.querySelector(".site-nav");

        // Index Drawer Elements
        const indexToggle = document.getElementById("index-toggle");
        const indexDrawer = document.getElementById("index-drawer");
        const closeIndex = document.getElementById("close-index");
        const drawerOverlay = document.getElementById("drawer-overlay");

        if (!menuToggle || !navLinksMobile || !siteNav) return;

        // Toggle Principal (Hamburguesa)
        const toggleMenu = (e: any) => {
          if (e) e.preventDefault();
          const isOpen = siteNav.classList.toggle("is-menu-open");
          menuToggle.classList.toggle("active");

          // Cerrar el índice si se abre el menú principal
          if (indexDrawer) {
            indexDrawer.classList.remove("open");
            if (drawerOverlay) drawerOverlay.classList.remove("visible");
          }

          document.body.style.overflow = isOpen ? "hidden" : "";
        };

        const closeMenu = () => {
          siteNav.classList.remove("is-menu-open");
          menuToggle.classList.remove("active");
          document.body.style.overflow = "";
        };

        (menuToggle as any).onclick = toggleMenu;

        const links = navLinksMobile.querySelectorAll("a");
        links.forEach((link) => {
          (link as any).onclick = closeMenu;
        });

        // Lógica del Índice
        if (indexToggle && indexDrawer) {
          indexToggle.onclick = () => {
            indexDrawer.classList.add("open");
            if (drawerOverlay) drawerOverlay.classList.add("visible");
            document.body.style.overflow = "hidden";

            // Cerrar menú principal si se abre el índice
            closeMenu();
          };

          const closeDrawerFunc = () => {
            indexDrawer.classList.remove("open");
            if (drawerOverlay) drawerOverlay.classList.remove("visible");
            document.body.style.overflow = "";
          };

          if (closeIndex) closeIndex.onclick = closeDrawerFunc;
          if (drawerOverlay) drawerOverlay.onclick = closeDrawerFunc;

          // Cerrar al pulsar un enlace del índice
          const drawerLinks = indexDrawer.querySelectorAll(".drawer-link");
          drawerLinks.forEach((link) => {
            (link as any).onclick = closeDrawerFunc;
          });
        }
      }

      // Inicializar
      initMenu();

      // Compatibilidad con transiciones de Astro
      document.addEventListener("astro:after-swap", initMenu);
    </script>
    <script is:inline>
      (function () {
        const hierEl = document.getElementById("uml-hier");
        const erEl = document.getElementById("uml-er");
        if (!hierEl && !erEl) return;

