---
import DocLayout from "../layouts/DocLayout.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Documentación Técnica | Nexus App - Arquitectura y Requisitos"
  description="Consulta la documentación oficial de Nexus App. Detalles sobre el plan de proyecto, análisis de requisitos, arquitectura del sistema y guías de implementación."
>
  <main class="docs-wrapper">
    
    <section class="page-hero">
      <h1 class="hero-title">Potencia técnica en cada búsqueda</h1>
      <p class="hero-subtitle">Diseñado para ofrecer precisión, velocidad y transparencia en datos.</p>
    </section>

    <section class="bento-grid-section">
      <div class="bento-container">
        
        <div class="bento-item main-feature">
          <span class="badge-tech">Core Engine</span>
          <h3>Búsqueda Multifuente</h3>
          <p>Nuestro algoritmo indexa en milisegundos múltiples plataformas simultáneamente.</p>
          <div class="visual-placeholder">
            <pre><code><span class="code-comment">// Nexus Core Indexer</span>
[System] Initializing multifetch...
[OK] Amazon API connected.
[OK] Wallapop Scraper active.
> Normalizing JSON payloads...
<span class="code-success">Success: 245 items formatted in 0.8s</span></code></pre>
          </div>
        </div>

        <div class="bento-item">
          <h3>Precios Reales</h3>
          <p>Sin filtros publicitarios ni resultados patrocinados.</p>
        </div>

        <div class="bento-item">
          <h3>API First</h3>
          <p>Construido para ser integrado. Documentación Swagger disponible.</p>
        </div>

      </div>
    </section>

    <hr class="section-divider" />

    <div class="tfg-content-container">
      <div class="doc-header">
        <p class="ecentia-partnership">
          Parte de <strong>Ecentia</strong>
        </p>
        <p class="doc-description">
          Esta sección reúne toda la documentación técnica y de gestión desarrollada
          para el Proyecto Final del Ciclo Formativo de Grado Superior en <strong>Desarrollo de Aplicaciones Multiplataforma (DAM)</strong>, realizado para el instituto <strong>IES Francisco Rodríguez Marín</strong>.
        </p>
      </div>

      <section id="introduccion">
        <span class="badge-tech">Documento General</span>
        <h2>Introducción y Contexto</h2>
        <p class="lead">
          Espacio para la introducción y contexto del proyecto Nexus.
        </p>
        <div class="placeholder-box">Contenido pendiente de redactar...</div>
      </section>

      <section id="analisis">
        <h2>Análisis y Requisitos</h2>
        <p>
          Definición de los requisitos funcionales y no funcionales, así como el
          análisis del dominio.
        </p>
        <div class="placeholder-box">Contenido pendiente de redactar...</div>
      </section>

      </div>
  </main>
</Layout>

<style>
  /* ── Contenedores principales ──────────────────────────────── */
  .docs-wrapper {
    background-color: var(--bg-primary, #0a0a0a);
    color: var(--text-main, #ededed);
    padding-bottom: 5rem;
  }

  .tfg-content-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ── Hero de la página ─────────────────────────────────────── */
  .page-hero {
    max-width: 1100px;
    margin: 4rem auto 2rem;
    padding: 0 2rem;
  }

  .hero-title {
    font-size: 3.5rem;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
    color: #ffffff;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: #a1a1a1;
    max-width: 600px;
  }

  /* ── Bento Grid (Basado en la captura) ─────────────────────── */
  .bento-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  @media (min-width: 768px) {
    .bento-container {
      grid-template-columns: 1.8fr 1fr;
      grid-template-rows: repeat(2, minmax(200px, auto));
    }
    .main-feature {
      grid-row: span 2;
    }
  }

  .bento-item {
    background: #141414; /* Gris muy oscuro */
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: 2.5rem;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }

  .bento-item:hover {
    border-color: rgba(255, 255, 255, 0.2);
    transform: translateY(-2px);
  }

  .bento-item h3 {
    font-size: 1.5rem;
    font-weight: 600;
    color: #ffffff;
    margin: 0 0 0.5rem 0;
  }

  .bento-item p {
    font-size: 1rem;
    color: #9ca3af;
    line-height: 1.6;
    margin: 0;
  }

  .badge-tech {
    display: inline-block;
    align-self: flex-start;
    padding: 6px 12px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #ffffff;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
  }

  /* Simulación de código para el bloque principal */
  .visual-placeholder {
    margin-top: 2rem;
    background: #0a0a0a;
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 8px;
    padding: 1.5rem;
    flex-grow: 1;
  }

  .visual-placeholder pre {
    margin: 0;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.85rem;
    color: #a1a1a1;
  }

  .code-comment { color: #6b7280; }
  .code-success { color: #34d399; }

  /* ── Separador y estilos para el TFG ───────────────────────── */
  .section-divider {
    margin: 5rem 0;
    border: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* Ajustes para el texto oscuro de tu antiguo layout para que se vea en fondo negro */
  .tfg-content-container h2 {
    font-size: 2rem;
    color: #ffffff;
    margin: 3rem 0 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    padding-bottom: 0.5rem;
  }

  .tfg-content-container p {
    color: #a1a1a1;
    line-height: 1.8;
  }

  .placeholder-box {
    padding: 2rem;
    background: rgba(255,255,255,0.02);
    border: 1px dashed rgba(255,255,255,0.2);
    border-radius: 12px;
    color: #6b7280;
    text-align: center;
    margin: 1.5rem 0;
    font-style: italic;
  }
</style>

<script>
  function loadFigma(containerId: string, figmaUrl: string) {
    // Unload all others (mutual exclusivity)
    document.querySelectorAll(".figma-embed-container").forEach((c) => {
      if (c.id !== containerId) unloadFigma(c.id);
    });

    const container = document.getElementById(containerId);
    if (!container || container.querySelector("iframe")) return;

    const loadButton = container.querySelector(
      ".load-figma-button",
    ) as HTMLElement | null;
    const loader = container.querySelector(".figma-loading-spinner");

    if (loadButton) loadButton.style.display = "none";
    if (loader) {
      loader.classList.add("is-loading");
    }

    const iframe = document.createElement("iframe");
    // Forzamos escalado 'contain' para que ocupe todo el div
    const separator = figmaUrl.includes("?") ? "&" : "?";
    iframe.src = `${figmaUrl}${separator}hide-ui=1&scaling=contain`;
    iframe.setAttribute("allowfullscreen", "true");
    iframe.style.width = "100%";
    iframe.style.height = "100%";
    iframe.style.border = "0";

    iframe.onload = () => {
      iframe.classList.add("is-loaded");
      if (loader) loader.classList.remove("is-loading");
    };

    container.appendChild(iframe);
  }

  function unloadFigma(containerId: string) {
    const container = document.getElementById(containerId);
    if (!container) return;

    const iframe = container.querySelector("iframe");
    if (iframe) iframe.remove();

    const loadButton = container.querySelector(
      ".load-figma-button",
    ) as HTMLElement | null;
    if (loadButton) loadButton.style.display = "flex";

    const loader = container.querySelector(".figma-loading-spinner");
    if (loader) loader.classList.remove("is-loading");
  }

  document.addEventListener("DOMContentLoaded", () => {
    const url1 =
      "https://embed.figma.com/design/wpSIqRPIp3jrXk80gQQoMm/Nexus-Dise%C3%B1o?embed-host=share";
    const url2 =
      "https://embed.figma.com/proto/wpSIqRPIp3jrXk80gQQoMm/Nexus-Dise%C3%B1o?node-id=1-2&content-scaling=fixed&page-id=0%3A1&starting-point-node-id=1%3A2&embed-host=share";

    const containers = document.querySelectorAll(".figma-embed-container");
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          // Si sale de vista, descargamos
          if (!entry.isIntersecting) {
            unloadFigma(entry.target.id);
          }
        });
      },
      { threshold: 0.1 },
    );

    containers.forEach((container) => {
      observer.observe(container);
      const btn = container.querySelector(
        ".load-figma-button",
      ) as HTMLElement | null;
      const url = container.id === "figma-container-1" ? url1 : url2;
      if (btn) {
        btn.onclick = () => loadFigma(container.id, url);
      }
    });
  });
</script>
