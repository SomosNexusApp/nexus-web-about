<script>
  function loadFigma(containerId: string, figmaUrl: string) {
    // Unload all others (mutual exclusivity)
    document.querySelectorAll(".figma-embed-container").forEach((c) => {
      if (c.id !== containerId) unloadFigma(c.id);
    });

    const container = document.getElementById(containerId);
    if (!container || container.querySelector("iframe")) return;

    const loadButton = container.querySelector(
      ".load-figma-button",
    ) as HTMLElement | null;
    const loader = container.querySelector(".figma-loading-spinner");

    if (loadButton) loadButton.style.display = "none";
    if (loader) {
      loader.classList.add("is-loading");
    }

    const iframe = document.createElement("iframe");
    // Forzamos escalado 'contain' para que ocupe todo el div
    const separator = figmaUrl.includes("?") ? "&" : "?";
    iframe.src = `${figmaUrl}${separator}hide-ui=1&scaling=contain`;
    iframe.setAttribute("allowfullscreen", "true");
    iframe.style.width = "100%";
    iframe.style.height = "100%";
    iframe.style.border = "0";

    iframe.onload = () => {
      iframe.classList.add("is-loaded");
      if (loader) loader.classList.remove("is-loading");
    };

    container.appendChild(iframe);
  }

  function unloadFigma(containerId: string) {
    const container = document.getElementById(containerId);
    if (!container) return;

    const iframe = container.querySelector("iframe");
    if (iframe) iframe.remove();

    const loadButton = container.querySelector(
      ".load-figma-button",
    ) as HTMLElement | null;
    if (loadButton) loadButton.style.display = "flex";

    const loader = container.querySelector(".figma-loading-spinner");
    if (loader) loader.classList.remove("is-loading");
  }

  document.addEventListener("DOMContentLoaded", () => {
    const url1 =
      "https://embed.figma.com/design/wpSIqRPIp3jrXk80gQQoMm/Nexus-Dise%C3%B1o?embed-host=share";
    const url2 =
      "https://embed.figma.com/proto/wpSIqRPIp3jrXk80gQQoMm/Nexus-Dise%C3%B1o?node-id=1-2&content-scaling=fixed&page-id=0%3A1&starting-point-node-id=1%3A2&embed-host=share";

    const containers = document.querySelectorAll(".figma-embed-container");
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          // Si sale de vista, descargamos
          if (!entry.isIntersecting) {
            unloadFigma(entry.target.id);
          }
        });
      },
      { threshold: 0.1 },
    );

    containers.forEach((container) => {
      observer.observe(container);
      const btn = container.querySelector(
        ".load-figma-button",
      ) as HTMLElement | null;
      const url = container.id === "figma-container-1" ? url1 : url2;
      if (btn) {
        btn.onclick = () => loadFigma(container.id, url);
      }
    });
  });
</script>
