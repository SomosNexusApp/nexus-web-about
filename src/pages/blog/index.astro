---
import Layout from '../../layouts/Layout.astro';

const posts = [
    {
        id: "1",
        title: "La arquitectura de Nexus: De Spring Boot a Astro",
        excerpt: "Exploramos cómo hemos unificado un backend robusto en Java con un frontend ultrarrápido utilizando Astro para nuestra web de marketing.",
        date: "24 Abr 2026",
        readTime: "5 min",
        category: "Arquitectura",
        image: "https://images.unsplash.com/photo-1517694712202-14dd9538aa97?auto=format&fit=crop&w=800&q=80",
        featured: true
    },
    {
        id: "2",
        title: "Diseñando para el ahorro: El sistema de diseño de Nexus",
        excerpt: "Cómo creamos una experiencia visual que transmite confianza y facilita la búsqueda de las mejores ofertas.",
        date: "20 Abr 2026",
        readTime: "4 min",
        category: "Diseño UX/UI",
        image: "https://images.unsplash.com/photo-1558655146-d09347e92766?auto=format&fit=crop&w=800&q=80",
        featured: false
    },
    {
        id: "3",
        title: "Integración de IA en soporte: El futuro de Nexus",
        excerpt: "Implementando Groq y Gemini para ofrecer una asistencia inmediata y humana a todos nuestros usuarios.",
        date: "15 Abr 2026",
        readTime: "6 min",
        category: "IA",
        image: "https://images.unsplash.com/photo-1677442136019-21780ecad995?auto=format&fit=crop&w=800&q=80",
        featured: false
    },
    {
        id: "4",
        title: "Despliegue escalable con Docker y Render",
        excerpt: "Nuestra estrategia para mantener una disponibilidad del 99.9% utilizando contenedores y despliegue continuo.",
        date: "10 Abr 2026",
        readTime: "7 min",
        category: "DevOps",
        image: "https://images.unsplash.com/photo-1607799279861-4dd421887fb3?auto=format&fit=crop&w=800&q=80",
        featured: false
    },
    {
        id: "5",
        title: "Lanzamiento de Nexus Beta: Primeros resultados",
        excerpt: "Analizamos el feedback de nuestra comunidad inicial y los próximos pasos en nuestra hoja de ruta.",
        date: "05 Abr 2026",
        readTime: "3 min",
        category: "Comunidad",
        image: "/assets/CEOs/foto_ceos_oficina.png",
        featured: false
    }
];

const featuredPost = posts.find(p => p.featured);
const regularPosts = posts.filter(p => !p.featured);
---

<Layout 
	title="Blog de Innovación | Nexus App - Tecnología, Diseño y Ahorro"
	description="Mantente al día con las últimas noticias de Nexus. Artículos sobre desarrollo web, diseño de productos, inteligencia artificial y consejos para ahorrar de forma inteligente."
>
	<div class="page-force-white">
		<main class="blog-page">
			<header class="blog-header">
				<div class="container">
					<h1 class="blog-title">Historias de <span>Innovación</span></h1>
					<p class="blog-lead">
						Explora nuestros últimos artículos sobre tecnología, diseño y el futuro del ahorro inteligente.
					</p>
				</div>
			</header>

			<div class="container">
				{featuredPost && (
					<article class="featured-card">
						<div class="featured-img-wrap">
							<img src={featuredPost.image} alt={featuredPost.title} />
						</div>
						<div class="featured-content">
							<div class="post-meta">
								<span class="category-badge">{featuredPost.category}</span>
								<span class="meta-item">{featuredPost.date}</span>
								<span class="meta-item">{featuredPost.readTime}</span>
							</div>
							<h2>{featuredPost.title}</h2>
							<p>{featuredPost.excerpt}</p>
							<a href={`/blog/${featuredPost.id}`} class="read-more">Leer artículo completo &rarr;</a>
						</div>
					</article>
				)}

				<div class="blog-grid">
					{regularPosts.map((post) => (
						<article class="post-card">
							<div class="post-img-wrap">
								<img src={post.image} alt={post.title} />
								<span class="post-category">{post.category}</span>
							</div>
							<div class="post-content">
								<div class="post-meta-small">
									<span>{post.date}</span>
									<span class="dot">•</span>
									<span>{post.readTime}</span>
								</div>
								<h3>{post.title}</h3>
								<p>{post.excerpt}</p>
								<a href={`/blog/${post.id}`} class="post-link">Saber más</a>
							</div>
						</article>
					))}
				</div>
			</div>
		</main>
	</div>
</Layout>

<style is:global>
	/* Forzar fondo blanco */
	.page-force-white {
		background-color: #ffffff !important;
		min-height: 100vh;
		width: 100%;
		position: relative;
		z-index: 1;
	}
	
	body:has(.page-force-white) {
		background-color: #ffffff !important;
	}

	/* Header Blanco Adaptado */
	.site-nav {
		background-color: rgba(255, 255, 255, 0.8) !important;
		backdrop-filter: blur(10px) !important;
		border-bottom: 1px solid #eee !important;
	}

	.site-nav a, .site-nav span, .site-nav .nav-contact span {
		color: #1a1a1a !important;
	}

	.site-nav .nav-line {
		background-color: #eee !important;
	}

	.site-nav .social-icon {
		background: #f0f0f0 !important;
		color: #111 !important;
	}

	.site-nav .social-icon:hover {
		background: #e0e0e0 !important;
	}

	.site-nav .hamburger-line {
		background-color: #000000 !important;
	}

	.site-nav .social-icon svg {
		stroke: #1a1a1a !important;
	}

	.is-menu-open .header-inline-nav {
		background: rgba(255, 255, 255, 0.98) !important;
	}

	.is-menu-open .header-inline-nav a {
		color: #000000 !important;
	}

	/* Blog Styles */
	.blog-page {
		color: #1a1a1a;
		padding-top: 140px;
		padding-bottom: 120px;
	}

	.blog-header {
		margin-bottom: 80px;
	}

	.blog-tag {
		display: inline-block;
		padding: 6px 16px;
		background: rgba(157, 90, 229, 0.1);
		color: #9d5ae5;
		border-radius: 100px;
		font-size: 12px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 2px;
		margin-bottom: 24px;
	}

	.blog-title {
		font-size: clamp(3rem, 10vw, 5.5rem);
		font-weight: 900;
		line-height: 0.9;
		letter-spacing: -4px;
		margin-bottom: 30px;
		color: #000000;
	}

	.blog-title span {
		color: #9d5ae5;
		display: block;
	}

	.blog-lead {
		max-width: 600px;
		font-size: 20px;
		color: #666;
		line-height: 1.6;
	}

	/* Featured Card */
	.featured-card {
		display: grid;
		grid-template-columns: 1.2fr 1fr;
		gap: 60px;
		background: #fcfcfc;
		border: 1px solid #eee;
		border-radius: 32px;
		overflow: hidden;
		margin-bottom: 80px;
		transition: transform 0.4s ease, box-shadow 0.4s ease;
	}

	.featured-card:hover {
		transform: translateY(-5px);
		box-shadow: 0 30px 60px rgba(0,0,0,0.08);
	}

	.featured-img-wrap {
		height: 500px;
		overflow: hidden;
	}

	.featured-img-wrap img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.8s ease;
	}

	.featured-card:hover .featured-img-wrap img {
		transform: scale(1.05);
	}

	.featured-content {
		padding: 60px 60px 60px 0;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.post-meta {
		display: flex;
		align-items: center;
		gap: 20px;
		margin-bottom: 30px;
	}

	.category-badge {
		background: #000;
		color: #fff;
		padding: 4px 14px;
		border-radius: 100px;
		font-size: 12px;
		font-weight: 700;
	}

	.meta-item {
		color: #888;
		font-size: 14px;
		font-weight: 500;
	}

	.featured-content h2 {
		font-size: 42px;
		font-weight: 800;
		line-height: 1.1;
		margin-bottom: 24px;
		letter-spacing: -1.5px;
		color: #111;
	}

	.featured-content p {
		font-size: 18px;
		color: #555;
		line-height: 1.7;
		margin-bottom: 30px;
	}

	.read-more {
		font-weight: 700;
		color: #9d5ae5;
		text-decoration: none;
		font-size: 16px;
		transition: transform 0.3s;
		display: inline-block;
	}

	.read-more:hover {
		transform: translateX(10px);
	}

	/* Blog Grid */
	.blog-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
		gap: 40px;
	}

	.post-card {
		background: #fff;
		border: 1px solid #eee;
		border-radius: 24px;
		overflow: hidden;
		transition: all 0.4s ease;
	}

	.post-card:hover {
		transform: translateY(-10px);
		box-shadow: 0 20px 40px rgba(0,0,0,0.05);
		border-color: #9d5ae5;
	}

	.post-img-wrap {
		height: 250px;
		position: relative;
		overflow: hidden;
	}

	.post-img-wrap img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s ease;
	}

	.post-card:hover .post-img-wrap img {
		transform: scale(1.1);
	}

	.post-category {
		position: absolute;
		top: 20px;
		left: 20px;
		background: rgba(255, 255, 255, 0.9);
		backdrop-filter: blur(5px);
		padding: 4px 12px;
		border-radius: 100px;
		font-size: 11px;
		font-weight: 800;
		color: #000;
		text-transform: uppercase;
	}

	.post-content {
		padding: 30px;
	}

	.post-meta-small {
		display: flex;
		align-items: center;
		gap: 10px;
		font-size: 13px;
		color: #888;
		margin-bottom: 16px;
		font-weight: 500;
	}

	.dot {
		color: #ddd;
	}

	.post-content h3 {
		font-size: 24px;
		font-weight: 700;
		margin-bottom: 12px;
		line-height: 1.3;
		letter-spacing: -0.5px;
		color: #111;
	}

	.post-content p {
		font-size: 15px;
		color: #666;
		line-height: 1.6;
		margin-bottom: 20px;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.post-link {
		font-weight: 700;
		color: #111;
		text-decoration: none;
		font-size: 14px;
		border-bottom: 2px solid #9d5ae5;
		padding-bottom: 2px;
		transition: all 0.3s;
	}

	.post-link:hover {
		color: #9d5ae5;
		padding-bottom: 5px;
	}

	@media (max-width: 1100px) {
		.featured-card {
			grid-template-columns: 1fr;
		}
		.featured-content {
			padding: 40px;
		}
		.featured-img-wrap {
			height: 350px;
		}
	}

	@media (max-width: 768px) {
		.blog-page {
			padding-top: 120px;
		}
		.blog-title {
			font-size: 3.5rem;
		}
		.featured-content h2 {
			font-size: 32px;
		}
	}
</style>

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

<script is:inline>
	document.addEventListener('DOMContentLoaded', () => {
		if (typeof gsap !== 'undefined') {
			gsap.registerPlugin(ScrollTrigger);

			gsap.from('.blog-header > *', {
				y: 40,
				opacity: 0,
				duration: 1,
				stagger: 0.2,
				ease: 'power4.out'
			});

			gsap.from('.featured-card', {
				y: 60,
				opacity: 0,
				duration: 1.2,
				ease: 'power3.out',
				delay: 0.4
			});

			const postCards = document.querySelectorAll('.post-card');
			postCards.forEach(card => {
				gsap.from(card, {
					scrollTrigger: {
						trigger: card,
						start: 'top 90%',
						toggleActions: 'play none none none'
					},
					y: 40,
					opacity: 0,
					duration: 0.8,
					ease: 'power3.out'
				});
			});
		}
	});
</script>
